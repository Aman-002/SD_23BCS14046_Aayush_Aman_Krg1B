        <mxCell id="MV9FI8kezUqbiXos9NSk-6" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="C. Client should be able to follow each other (or send friend requests)" vertex="1">
          <mxGeometry height="30" width="390" x="550" y="652" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-7" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="D.Client should be able to like or comment on the post" vertex="1">
          <mxGeometry height="30" width="310" x="550" y="692" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-8" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="E. Client should be able to view the feed of post from users they follow" vertex="1">
          <mxGeometry height="30" width="400" x="550" y="732" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-9" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;2. Non-Functional Requirements&amp;nbsp;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="550" y="852" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-10" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="A. Scalability: 500M DAU" vertex="1">
          <mxGeometry height="30" width="160" x="550" y="892" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-11" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="B. Consistency &amp;amp; Availability:" vertex="1">
          <mxGeometry height="30" width="180" x="550" y="932" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-12" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="In this case -&amp;gt; Social Media" vertex="1">
          <mxGeometry height="30" width="170" x="590" y="952" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-13" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. We need our application to be HIGHLY available, then consistent" vertex="1">
          <mxGeometry height="30" width="380" x="590" y="972" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-14" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Reason: If it is not operational / Functional when it was required, then there is no&lt;br&gt;meaning of developing the application." vertex="1">
          <mxGeometry height="40" width="450" x="600" y="992" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-15" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Eg: Suppose, Instagram is down for 1 hour -&amp;gt; Big Picture issue" vertex="1">
          <mxGeometry height="30" width="360" x="610" y="1032" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-16" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="But, on the other hand, Instagram was up and running, and you posted something" vertex="1">
          <mxGeometry height="30" width="460" x="610" y="1052" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-17" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="which took 500 ms to reach you followers -&amp;gt; is it a issue?? Compared to availability" vertex="1">
          <mxGeometry height="30" width="460" x="610" y="1072" as="geometry" />
        </mxCell>
        <mxCell id="MV9FI8kezUqbiXos9NSk-18" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Hence, Availability &amp;gt;&amp;gt;&amp;gt;&amp;gt; Consistency" vertex="1">
          <mxGeometry height="30" width="220" x="610" y="1102" as="geometry" />
        </mxCell>
